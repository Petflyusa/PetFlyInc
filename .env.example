# Environment Variables — Pet Fly Inc
# Copy this file to .env and fill in your values
# NEVER commit .env to version control

# Server
PORT=3000
NODE_ENV=development

# Session
SESSION_SECRET=change_this_to_a_long_random_string_in_production

# MySQL (Hostinger)
DB_HOST=srv1134.hstgr.io
DB_PORT=3306
DB_NAME=u884869254_petflyinc
DB_USER=u884869254_petflyinc
DB_PASSWORD=your_mysql_password

# SMTP (Hostinger Email)
SMTP_HOST=smtp.hostinger.com
SMTP_PORT=465
SMTP_USER=info@yourdomain.com
SMTP_PASS=your_email_password

# File Uploads
UPLOAD_DIR=./public/uploads
MAX_FILE_SIZE=5242880

# Site URL (used for email links, etc.)
SITE_URL=http://localhost:3000
