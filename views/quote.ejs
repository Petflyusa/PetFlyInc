<%- include('partials/header', { currentPage: 'quote' }) %>

<script>
var petCounter = 1;

function addPetEntry() {
    petCounter++;
    var container = document.getElementById('petsContainer');
    var div = document.createElement('div');
    div.className = 'pet-entry';
    div.id = 'pet-' + petCounter;
    div.style.cssText = 'margin-top: var(--space-md); padding: var(--space-md); background: rgba(247,245,240,0.03); border: 1px solid rgba(247,245,240,0.1); border-radius: 4px; position: relative;';
    div.innerHTML =
        '<div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:var(--space-sm);">' +
            '<span style="font-size:0.75rem;text-transform:uppercase;letter-spacing:0.05em;color:var(--accent);font-weight:500;">Pet #'+petCounter+'</span>' +
            '<button type="button" onclick="removePetEntry('+petCounter+')" class="remove-pet-btn">Remove</button>' +
        '</div>' +
        '<div class="form-grid" style="grid-template-columns:1fr 1fr;">' +
            '<div class="form-group">' +
                '<label>Pet Type *</label>' +
                '<select class="form-control" name="pet_type_'+petCounter+'" required>' +
                    '<option value="">Select</option>' +
                    '<option value="Dog">Dog</option>' +
                    '<option value="Cat">Cat</option>' +
                    '<option value="Bird">Bird</option>' +
                    '<option value="Rabbit">Rabbit</option>' +
                    '<option value="Other">Other</option>' +
                '</select>' +
            '</div>' +
            '<div class="form-group">' +
                '<label>Pet Name</label>' +
                '<input type="text" class="form-control" name="pet_name_'+petCounter+'" placeholder="Optional">' +
            '</div>' +
            '<div class="form-group">' +
                '<label>Breed</label>' +
                '<input type="text" class="form-control" name="breed_'+petCounter+'" placeholder="e.g., Golden Retriever">' +
            '</div>' +
            '<div class="form-group">' +
                '<label>Color</label>' +
                '<input type="text" class="form-control" name="pet_color_'+petCounter+'" placeholder="e.g., Golden">' +
            '</div>' +
            '<div class="form-group">' +
                '<label>Gender</label>' +
                '<select class="form-control" name="pet_gender_'+petCounter+'">' +
                    '<option value="">Select</option>' +
                    '<option value="Male">Male</option>' +
                    '<option value="Female">Female</option>' +
                '</select>' +
            '</div>' +
            '<div class="form-group">' +
                '<label>Date of Birth</label>' +
                '<input type="date" class="form-control" name="pet_dob_'+petCounter+'">' +
            '</div>' +
            '<div class="form-group full">' +
                '<label>Microchip Number</label>' +
                '<input type="text" class="form-control" name="microchip_'+petCounter+'" placeholder="15-digit ISO chip number (optional)">' +
            '</div>' +
        '</div>';
    container.appendChild(div);
}

function removePetEntry(id) {
    var count = document.querySelectorAll('.pet-entry').length;
    if (count <= 1) return;
    var el = document.getElementById('pet-' + id);
    if (el) el.remove();
}

function togglePickupDelivery() {
    var checked = document.getElementById('pickupDelivery').checked;
    document.getElementById('pickupDeliverySection').style.display = checked ? 'block' : 'none';
}

function submitQuoteForm(event) {
    event.preventDefault();
    var form = document.getElementById('quoteForm');
    var btn = form.querySelector('button[type="submit"]');
    var orig = btn.innerHTML;
    btn.innerHTML = '<i class="fas fa-spinner fa-spin"></i> Sending...';
    btn.disabled = true;

    var fd = new FormData(form);
    var data = {};
    fd.forEach(function(value, key) { data[key] = value; });

    // Collect all pet entries into arrays
    var petTypes = [], petNames = [], breeds = [], petDobs = [], petColors = [], petGenders = [], microchips = [];
    var idx = 1;
    while (document.getElementById('pet-' + idx) || idx === 1) {
        if (idx === 1 || document.getElementById('pet-' + idx)) {
            var t = data['pet_type_' + idx] || data['pet_type'];
            var n = data['pet_name_' + idx] || data['pet_name'];
            var b = data['breed_' + idx] || data['breed'];
            var d = data['pet_dob_' + idx] || data['pet_dob'];
            var c = data['pet_color_' + idx] || data['pet_color'];
            var g = data['pet_gender_' + idx] || data['pet_gender'];
            var m = data['microchip_' + idx] || data['microchip'];
            if (t) petTypes.push(t);
            if (n) petNames.push(n);
            if (b) breeds.push(b);
            if (d) petDobs.push(d);
            if (c) petColors.push(c);
            if (g) petGenders.push(g);
            if (m) microchips.push(m);
        }
        idx++;
        if (idx > 20) break;
    }

    // Replace flat fields with arrays
    if (petTypes.length) data.pet_type = petTypes.join('|');
    if (petNames.length) data.pet_name = petNames.join('|');
    if (breeds.length) data.breed = breeds.join('|');
    if (petDobs.length) data.pet_dob = petDobs.join('|');
    if (petColors.length) data.pet_color = petColors.join('|');
    if (petGenders.length) data.pet_gender = petGenders.join('|');
    if (microchips.length) data.microchip = microchips.join('|');

    // Remove numbered sub-fields
    Object.keys(data).forEach(function(k) {
        if (k.match(/_\d+$/)) delete data[k];
    });

    fetch('/api/quote', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(data)
    })
    .then(function(r) { return r.json(); })
    .then(function(d) {
        if (d.success) {
            document.getElementById('formContent').innerHTML = '<div class="success-message"><i class="fas fa-check"></i><h2>Request Received</h2><p>We\'ll be in touch within 24 hours.</p></div>';
        } else {
            alert('Error: ' + (d.message || 'Submission failed'));
            btn.innerHTML = orig;
            btn.disabled = false;
        }
    })
    .catch(function() {
        alert('An error occurred. Please try again.');
        btn.innerHTML = orig;
        btn.disabled = false;
    });
}
</script>
<style>
.add-pet-btn {
  margin-top: var(--space-sm);
  background: rgba(247, 245, 240, 0.05);
  border: 1px dashed rgba(247, 245, 240, 0.5);
  color: rgba(247, 245, 240, 0.9);
  padding: 0.65rem 1rem;
  font-size: 0.9rem;
  cursor: pointer;
  width: 100%;
  font-family: var(--font-sans);
  transition: all 0.2s;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 0.5rem;
  border-radius: 4px;
}
.add-pet-btn:hover {
  border-color: var(--accent);
  color: var(--accent);
  background: rgba(189, 155, 90, 0.12);
}
.pet-entry .remove-pet-btn {
  background: rgba(247, 245, 240, 0.06);
  border: 1px solid rgba(247, 245, 240, 0.2);
  color: rgba(247, 245, 240, 0.7);
  cursor: pointer;
  font-size: 0.75rem;
  padding: 0.2rem 0.5rem;
  border-radius: 3px;
  transition: all 0.2s;
  flex-shrink: 0;
}
.pet-entry .remove-pet-btn:hover {
  border-color: #dc4040;
  color: #ff8080;
}
</style>

  <!-- PAGE HEADER -->
  <section class="page-header" style="color: var(--cream);">
    <video class="page-header-video" autoplay muted loop playsinline poster="/videos/quotehero-poster.jpg">
      <source src="/videos/quotehero.mp4" type="video/mp4">
    </video>
    <div class="page-header-overlay"></div>
    <div class="container">
      <span class="section-label">Transport Quote</span>
      <h1 style="color: var(--cream);">Request your<br>personalised quote.</h1>
      <p style="color: rgba(247, 245, 240, 0.75);">Fill in the details below and we'll respond within 24 hours with a tailored plan for your pet's journey.</p>
    </div>
  </section>

  <!-- QUOTE FORM -->
  <section class="section">
    <div class="container">
      <div class="quote-layout">

        <div class="quote-aside">
          <span class="section-label">What to expect</span>
          <h2>A quote as unique as your companion.</h2>
          <p>Every transport is different. The quote you receive will be based on your pet's breed, size, destination, and preferred level of service.</p>
          <ul class="feature-list" style="margin-top: var(--space-md);">
            <li>Personalised route planning</li>
            <li>Transparent pricing — no hidden fees</li>
            <li>Timeline estimates for your specific journey</li>
            <li>Container recommendations</li>
          </ul>
          <div style="margin-top: var(--space-lg); padding: var(--space-md); background: var(--cream); border-left: 2px solid var(--accent);">
            <p style="font-size: 0.9375rem; color: var(--text-muted); line-height: 1.7;">
              Need urgent assistance? Our emergency line is available 24/7 for existing shipments.
              <br><br>
              <a href="tel:+162****5666" style="font-family: var(--font-serif); font-size: 1.125rem; color: var(--charcoal); border-bottom: 1px solid var(--warm-gray-300);">
                +1 (626) 656-5666
              </a>
            </p>
          </div>
        </div>

        <div class="form-container" id="formContent">
          <form id="quoteForm" onsubmit="submitQuoteForm(event)">

            <div style="margin-bottom: var(--space-lg);">
              <span class="section-label" style="margin-bottom: 1.5rem; display:block;">Pet Information</span>

              <div id="petsContainer">

                <!-- Pet #1 -->
                <div class="pet-entry" id="pet-1">
                  <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:var(--space-sm);">
                    <span style="font-size:0.75rem;text-transform:uppercase;letter-spacing:0.05em;color:var(--accent);font-weight:500;">Pet #1</span>
                    <button type="button" onclick="removePetEntry(1)" class="remove-pet-btn">Remove</button>
                  </div>
                  <div class="form-grid" style="grid-template-columns:1fr 1fr;">
                    <div class="form-group">
                      <label>Pet Type *</label>
                      <select class="form-control" name="pet_type" required>
                        <option value="">Select</option>
                        <option value="Dog">Dog</option>
                        <option value="Cat">Cat</option>
                        <option value="Bird">Bird</option>
                        <option value="Rabbit">Rabbit</option>
                        <option value="Other">Other</option>
                      </select>
                    </div>
                    <div class="form-group">
                      <label>Pet Name</label>
                      <input type="text" class="form-control" name="pet_name" placeholder="Optional">
                    </div>
                    <div class="form-group">
                      <label>Breed</label>
                      <input type="text" class="form-control" name="breed" placeholder="e.g., Golden Retriever">
                    </div>
                    <div class="form-group">
                      <label>Color</label>
                      <input type="text" class="form-control" name="pet_color" placeholder="e.g., Golden">
                    </div>
                    <div class="form-group">
                      <label>Gender</label>
                      <select class="form-control" name="pet_gender">
                        <option value="">Select</option>
                        <option value="Male">Male</option>
                        <option value="Female">Female</option>
                      </select>
                    </div>
                    <div class="form-group">
                      <label>Date of Birth</label>
                      <input type="date" class="form-control" name="pet_dob">
                    </div>
                    <div class="form-group full">
                      <label>Microchip Number</label>
                      <input type="text" class="form-control" name="microchip" placeholder="15-digit ISO chip number (optional)">
                    </div>
                  </div>
                </div>

              </div>

              <button type="button" onclick="addPetEntry()" class="add-pet-btn">
                <i class="fas fa-plus"></i> Add another pet
              </button>
            </div>

            <div style="margin-bottom: var(--space-lg);">
              <span class="section-label" style="margin-bottom: 1.5rem; display:block;">Route</span>
              <div class="form-grid">
                <div class="form-group">
                  <label>Origin Country *</label>
                  <input type="text" class="form-control" name="origin_country" placeholder="e.g., United States" required>
                </div>
                <div class="form-group">
                  <label>Origin City *</label>
                  <input type="text" class="form-control" name="origin_city" placeholder="e.g., Los Angeles" required>
                </div>
                <div class="form-group">
                  <label>Destination Country *</label>
                  <input type="text" class="form-control" name="dest_country" placeholder="e.g., China" required>
                </div>
                <div class="form-group">
                  <label>Destination City *</label>
                  <input type="text" class="form-control" name="dest_city" placeholder="e.g., Shanghai" required>
                </div>
                <div class="form-group">
                  <label>Travel Date</label>
                  <input type="date" class="form-control" name="travel_date">
                </div>
              </div>

              <!-- Pickup & Delivery Service -->
              <div style="margin-top: var(--space-md);">
                <label style="display:flex;align-items:center;gap:0.75rem;cursor:pointer;font-size:0.9rem;color:rgba(247,245,240,0.8);">
                  <input type="checkbox" id="pickupDelivery" name="pickup_delivery" onchange="togglePickupDelivery()" style="width:1rem;height:1rem;accent-color:var(--accent);cursor:pointer;">
                  <span>Pickup &amp; Delivery Service</span>
                </label>
              </div>

              <!-- Pickup & Delivery Address (shown when checkbox is checked) -->
              <div id="pickupDeliverySection" style="display:none;margin-top:var(--space-md);padding:var(--space-md);background:rgba(247,245,240,0.03);border:1px solid rgba(247,245,240,0.1);border-radius:4px;">
                <div class="form-grid">
                  <div class="form-group full">
                    <label>Pickup Address</label>
                    <input type="text" class="form-control" name="pickup_address" placeholder="Full street address">
                  </div>
                  <div class="form-group full">
                    <label>Delivery Address</label>
                    <input type="text" class="form-control" name="delivery_address" placeholder="Full street address">
                  </div>
                </div>
              </div>
            </div>

            <div style="margin-bottom: var(--space-lg);">
              <span class="section-label" style="margin-bottom: 1.5rem; display:block;">Your Details</span>
              <div class="form-grid">
                <div class="form-group">
                  <label>Your Name *</label>
                  <input type="text" class="form-control" name="contact_name" placeholder="Full name" required>
                </div>
                <div class="form-group">
                  <label>Email *</label>
                  <input type="email" class="form-control" name="email" placeholder="your@email.com" required>
                </div>
                <div class="form-group">
                  <label>Phone</label>
                  <input type="tel" class="form-control" name="phone" placeholder="+1 (555) 000-0000">
                </div>
                <div class="form-group">
                  <label>Transport Type</label>
                  <select class="form-control" name="transport_type">
                    <option value="">Select preference</option>
                    <option value="Cabin">Cabin (in aircraft cabin)</option>
                    <option value="Cargo">Cargo (hold)</option>
                    <option value="VIP Chauffeur">VIP Chauffeur</option>
                    <option value="Private">Private charter</option>
                  </select>
                </div>
              </div>
            </div>

            <div class="form-group full">
              <label>Additional Notes</label>
              <textarea class="form-control" name="notes" placeholder="Tell us more about your pet, special requirements, or questions..."></textarea>
            </div>

            <!-- Honeypot fields -->
            <div style="position:absolute;left:-9999px;" aria-hidden="true">
              <input type="text" name="fax_only" tabindex="-1" autocomplete="no">
              <input type="text" name="email_addr" tabindex="-1" autocomplete="no">
            </div>

            <button type="submit" class="btn-primary">
              Send Request <i class="fas fa-arrow-right" style="font-size: 0.7rem;"></i>
            </button>

          </form>
        </div>

      </div>
    </div>
  </section>

<%- include('partials/footer') %>
