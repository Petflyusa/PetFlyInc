<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <meta name="description" content="Pet Fly Inc - Your trusted partner for international pet transportation. IATA & USDA certified, 8+ years experience, serving 15+ countries.">
  <title><%= typeof pageTitle !== 'undefined' ? pageTitle : 'Pet Fly Inc' %></title>
  <link rel="stylesheet" href="/css/style-v2.css">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@400;500&family=DM+Sans:wght@300;400;500&display=swap" rel="stylesheet">
  <link rel="icon" type="image/png" sizes="64x64" href="/favicon.png">
  <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32.png">
  <link rel="icon" type="image/svg+xml" href="/favicon.svg">
  <style>
    .add-pet-btn {
      margin-top: var(--space-sm);
      background: rgba(189, 155, 90, 0.15);
      border: 1px solid var(--accent);
      color: var(--accent);
      padding: 0.65rem 1rem;
      font-size: 0.9rem;
      cursor: pointer;
      width: 100%;
      font-family: var(--font-sans);
      transition: all 0.2s;
      display: flex;
      align-items: center;
      justify-content: center;
      gap: 0.5rem;
      border-radius: 4px;
    }
    .add-pet-btn:hover {
      background: rgba(189, 155, 90, 0.25);
    }
    .pet-entry .remove-pet-btn {
      background: rgba(220, 64, 64, 0.1);
      border: 1px solid #dc4040;
      color: #ff8080;
      cursor: pointer;
      font-size: 0.75rem;
      padding: 0.25rem 0.6rem;
      border-radius: 3px;
      transition: all 0.2s;
      flex-shrink: 0;
      font-family: var(--font-sans);
    }
    .pet-entry .remove-pet-btn:hover {
      background: rgba(220, 64, 64, 0.2);
    }
  </style>
</head>
<body>

  <header id="siteHeader">
    <div class="container">
      <a href="/" class="logo">
        <div class="logo-icon"><i class="fas fa-plane"></i></div>
        Pet Fly Inc
      </a>
      <nav>
        <ul>
          <li><a href="/" <%= currentPage === 'index' ? 'class="active"' : '' %>>Home</a></li>
          <li><a href="/service" <%= currentPage === 'service' ? 'class="active"' : '' %>>Services</a></li>
          <li><a href="/quote" <%= currentPage === 'quote' ? 'class="active"' : '' %>>Quote</a></li>
          <li><a href="/regulations" <%= currentPage === 'regulations' ? 'class="active"' : '' %>>Regulations</a></li>
          <li><a href="/contact" <%= currentPage === 'contact' ? 'class="active"' : '' %>>Contact</a></li>
          <li><a href="/CRM" class="client-login-btn">Client Login</a></li>
        </ul>
      </nav>
      <div class="menu-toggle" onclick="document.querySelector('.mobile-nav').classList.toggle('active'); this.classList.toggle('active');">
        <span></span><span></span><span></span>
      </div>
    </div>
  </header>

  <div class="mobile-nav">
    <a href="/">Home</a>
    <a href="/service">Services</a>
    <a href="/quote">Quote</a>
    <a href="/regulations">Regulations</a>
    <a href="/contact">Contact</a>
    <a href="/CRM">Client Login</a>
  </div>

<script>
  window.addEventListener('scroll', function() {
    var h = document.getElementById('siteHeader');
    if (window.scrollY > 60) { h.classList.add('scrolled'); }
    else { h.classList.remove('scrolled'); }
  });
</script>
