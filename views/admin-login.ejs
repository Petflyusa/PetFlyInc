<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Admin Login — Pet Fly Inc</title>
  <link rel="stylesheet" href="/css/style-v2.css">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@400;500&family=DM+Sans:wght@300;400;500&display=swap" rel="stylesheet">
  <style>
    body { background: var(--charcoal); color: var(--cream); font-family: var(--font-sans); }
    .login-wrap {
      min-height: 100vh;
      display: flex;
      align-items: center;
      justify-content: center;
      padding: var(--space-lg);
    }
    .login-card {
      background: #1c1c1c;
      border: 1px solid rgba(247,245,240,0.1);
      padding: var(--space-xl);
      width: 100%;
      max-width: 400px;
    }
    .login-card h1 {
      font-family: var(--font-serif);
      font-size: 1.75rem;
      color: var(--cream);
      margin-bottom: 0.25rem;
    }
    .login-card p { color: rgba(247,245,240,0.5); font-size: 0.9375rem; margin-bottom: var(--space-lg); }
    .form-group label { color: rgba(247,245,240,0.7); font-size: 0.8125rem; text-transform: uppercase; letter-spacing: 0.05em; }
    .form-control {
      width: 100%;
      background: rgba(247,245,240,0.05);
      border: 1px solid rgba(247,245,240,0.15);
      color: var(--cream);
      padding: 0.75rem 1rem;
      font-size: 1rem;
      font-family: var(--font-sans);
      outline: none;
      transition: border-color 0.2s;
      box-sizing: border-box;
    }
    .form-control:focus { border-color: var(--accent); }
    .form-control::placeholder { color: rgba(247,245,240,0.25); }
    .btn-primary {
      width: 100%;
      background: var(--accent);
      color: var(--charcoal);
      border: none;
      padding: 0.875rem 1.5rem;
      font-size: 0.875rem;
      font-family: var(--font-sans);
      font-weight: 500;
      text-transform: uppercase;
      letter-spacing: 0.08em;
      cursor: pointer;
      transition: opacity 0.2s;
      display: flex;
      align-items: center;
      justify-content: center;
      gap: 0.5rem;
    }
    .btn-primary:hover { opacity: 0.85; }
    .btn-primary:disabled { opacity: 0.5; cursor: not-allowed; }
    .login-error {
      background: rgba(220, 50, 50, 0.15);
      border: 1px solid rgba(220, 50, 50, 0.4);
      color: #ff8080;
      padding: 0.75rem 1rem;
      font-size: 0.875rem;
      margin-bottom: var(--space-md);
      display: none;
    }
    .back-link {
      display: block;
      margin-top: var(--space-md);
      color: rgba(247,245,240,0.4);
      font-size: 0.875rem;
      text-align: center;
      text-decoration: none;
      transition: color 0.2s;
    }
    .back-link:hover { color: rgba(247,245,240,0.7); }
  </style>
</head>
<body>

<div class="login-wrap">
  <div class="login-card">
    <h1>Pet Fly Inc</h1>
    <p>Admin Panel</p>

    <div class="login-error" id="loginError"></div>

    <form id="loginForm" onsubmit="submitLogin(event)">
      <div class="form-group" style="margin-bottom: var(--space-md);">
        <label>Username</label>
        <input type="text" class="form-control" name="username" placeholder="Enter username" required autocomplete="username">
      </div>
      <div class="form-group" style="margin-bottom: var(--space-lg);">
        <label>Password</label>
        <input type="password" class="form-control" name="password" placeholder="Enter password" required autocomplete="current-password">
      </div>
      <button type="submit" class="btn-primary" id="loginBtn">
        Sign In <i class="fas fa-arrow-right" style="font-size: 0.7rem;"></i>
      </button>
    </form>

    <a href="/" class="back-link"><i class="fas fa-arrow-left" style="font-size: 0.7rem;"></i> Back to site</a>
  </div>
</div>

<script>
function submitLogin(event) {
    event.preventDefault();
    var btn = document.getElementById('loginBtn');
    var err = document.getElementById('loginError');
    var orig = btn.innerHTML;
    btn.innerHTML = '<i class="fas fa-spinner fa-spin"></i> Signing in...';
    btn.disabled = true;
    err.style.display = 'none';

    var fd = new FormData(document.getElementById('loginForm'));
    var obj = {};
    fd.forEach(function(v, k) { obj[k] = v; });
    fetch('/admin/login', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify(obj)
    })
    .then(function(r) { return r.json(); })
    .then(function(d) {
        if (d.success) {
            window.location.href = '/admin';
        } else {
            err.textContent = d.error || 'Login failed';
            err.style.display = 'block';
            btn.innerHTML = orig;
            btn.disabled = false;
        }
    })
    .catch(function() {
        err.textContent = 'Connection error. Please try again.';
        err.style.display = 'block';
        btn.innerHTML = orig;
        btn.disabled = false;
    });
}
</script>

</body>
</html>
