{
  "functions": {
    "api/**/*.php": {
      "runtime": "vercel-php@0.9.0"
    }
  },
  "rewrites": [
    {
      "source": "/(.*)\\.php",
      "destination": "/api/$1.php"
    },
    {
      "source": "/",
      "destination": "/api/index.php"
    },
    {
      "source": "/((?!api/|css/|.*\\.css|.*\\.js|.*\\.png|.*\\.jpg|.*\\.jpeg|.*\\.gif|.*\\.svg|.*\\.ico|.*\\.mp4|.*\\.php$).*)",
      "destination": "/api/$1.php"
    }
  ]
}
